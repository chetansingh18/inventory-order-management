# Root environment for Docker Compose.
# Copy to .env:  cp .env.example .env
# Credentials are read from here — never commit your real .env file.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=inventory

# Origins allowed to call the backend (comma-separated).
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000

# Dashboard low-stock threshold.
LOW_STOCK_THRESHOLD=10
