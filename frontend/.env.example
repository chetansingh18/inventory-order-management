# Frontend build-time environment variables (Vite).
#
# Leave VITE_API_BASE_URL empty for the Docker Compose / nginx setup, where
# the app calls the relative "/api" path and nginx proxies to the backend.
#
# For split deployments (frontend on Vercel/Netlify, backend on Render), set
# this to the full public backend URL, e.g.:
#   VITE_API_BASE_URL=https://your-backend.onrender.com
VITE_API_BASE_URL=

# Used only by `npm run dev` to point the local proxy at the backend.
VITE_DEV_BACKEND=http://localhost:8000
